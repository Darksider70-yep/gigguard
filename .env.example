# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/gigguard

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# ML Service
ML_SERVICE_URL=http://localhost:5001
ML_SERVICE_TIMEOUT_MS=500

# ML Service - Model Paths
FLASK_ENV=production
SAC_MODEL_PATH=/app/models/sac_premium_v1.zip
IF_MODEL_PATH=/app/models/isolation_forest.pkl
GNN_MODEL_PATH=/app/models/graphsage_fraud.pt
LOG_LEVEL=INFO

# OpenWeatherMap
OPENWEATHERMAP_API_KEY=your_key_here
OPENWEATHERMAP_BASE_URL=https://api.openweathermap.org/data/3.0

# AQICN
AQICN_API_KEY=your_key_here
AQICN_BASE_URL=https://api.waqi.info/feed

# Google Maps (hex backfill job)
GOOGLE_MAPS_API_KEY=your_key_here

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_ACCOUNT_NUMBER=1234567890
RAZORPAY_WEBHOOK_SECRET=xxx

# JWT
JWT_SECRET=your_secret_here

# Feature flags
USE_MOCK_APIS=true
USE_MOCK_PAYOUT=true
FEATURE_PANDEMIC_TRIGGER_ENABLED=true

# Health Emergency Webhook (Phase 3)
# Shared secret for HMAC-SHA256 signing of health emergency webhooks.
# Generate with: openssl rand -hex 32
HEALTH_WEBHOOK_SECRET=replace_with_32_char_minimum_random_secret

# App
PORT=4000
NODE_ENV=development
INSURER_LOGIN_SECRET=change_me_insurer_secret

# CORS
CORS_ORIGIN=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx

# Payment Service
PAYMENT_DRIVER=dummy
PAYMENT_SERVICE_KEY=super_secret_internal_key_that_is_at_least_32_chars_long
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_ACCOUNT_NUMBER=
