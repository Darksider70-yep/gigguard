# Backend
DATABASE_URL=postgresql://postgres:password@localhost:5432/gigguard
PORT=4000
ML_SERVICE_URL=http://localhost:5001
ML_TIMEOUT_MS=500
JWT_SECRET=change_me_backend_jwt_secret
INSURER_LOGIN_SECRET=change_me_insurer_secret
REDIS_URL=redis://localhost:6379
USE_MOCK_APIS=true

# Weather APIs
OPENWEATHER_API_KEY=your_key_here
AQI_API_KEY=your_key_here

# Geospatial APIs
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Payments (Razorpay sandbox)
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here
RAZORPAY_ACCOUNT_NUMBER=1234567890

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxx
